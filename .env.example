# Forex ML Terminal — Environment Variables
# Kopiere diese Datei als .env und fuege deine Keys ein

# FRED API Key (fuer Makrodaten in Schritt 2)
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage (optional, fuer OHLCV Daten)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Bearer-Token fuer backend/api (muss identisch als VITE_API_TOKEN in mobile/.env stehen)
# Erzeugen mit: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_TOKEN=your_generated_token_here
